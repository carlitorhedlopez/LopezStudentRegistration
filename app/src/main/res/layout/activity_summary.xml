<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">
    
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="48dp">

        <TextView
            android:id="@+id/tvWelcomeHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Welcome back,\nAlex"
            android:textAlignment="center"
            android:textColor="#FFFFFF"
            android:textSize="36sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.9"
            app:layout_constraintWidth_max="500dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tvSubHeader"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="You are securely logged into your\nuniversity portal."
            android:textAlignment="center"
            android:textColor="#A1A1AA"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvWelcomeHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.8"
            app:layout_constraintWidth_max="400dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="48dp" />

        <LinearLayout
            android:id="@+id/summaryCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:background="@drawable/bg_card"
            app:layout_constraintTop_toBottomOf="@id/tvSubHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.9"
            app:layout_constraintWidth_max="500dp"
            android:padding="24dp"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="48dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FULL NAME"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvNameVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Alex Mercer"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COURSE"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvCourseVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Computer Science BSCS"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textAlignment="center"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="YEAR OF STUDY"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvYearVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sophomore - Year 2"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textAlignment="center"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GENDER"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvGenderVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Male"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textAlignment="center"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UNIVERSITY EMAIL"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvEmailVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="a.mercer@university.edu"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textAlignment="center" />
        </LinearLayout>
        
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnReturnToLogin"
            android:layout_width="200dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_button"
            android:text="LOG OUT"
            android:textColor="#000000"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/summaryCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32dp"
            android:textAllCaps="true" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
