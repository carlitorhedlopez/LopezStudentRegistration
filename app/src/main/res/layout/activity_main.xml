<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="32dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:id="@+id/registrationCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintWidth_percent="0.9"
            app:layout_constraintWidth_max="500dp"
            android:background="@drawable/bg_card"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Student Registration"
                android:textAlignment="center"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="STUDENT NAME"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etName"
                style="@style/CustomInputText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="Enter full name"
                android:inputType="textPersonName"
                android:drawableStart="@drawable/ic_person"
                android:drawablePadding="12dp"
                android:paddingStart="16dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="EMAIL ADDRESS"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etEmail"
                style="@style/CustomInputText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="email@example.com"
                android:inputType="textEmailAddress"
                android:drawableStart="@drawable/ic_email"
                android:drawablePadding="12dp"
                android:paddingStart="16dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="PASSWORD"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etPassword"
                style="@style/CustomInputText"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:hint="........"
                android:inputType="textPassword"
                android:drawableStart="@drawable/ic_lock"
                android:drawableEnd="@drawable/ic_visibility_off"
                android:drawablePadding="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="COURSE"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="24dp">
                
                <ImageView
                    android:id="@+id/ivCourseIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_book"
                    android:contentDescription="Course"/>

                <Spinner
                    android:id="@+id/spCourse"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/ivCourseIcon"
                    android:layout_toStartOf="@+id/ivCourseArrow"
                    android:background="@android:color/transparent"
                    android:paddingHorizontal="12dp" />

                <ImageView
                    android:id="@+id/ivCourseArrow"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_arrow_down"
                    android:tint="#A1A1AA"
                    android:contentDescription="Dropdown" />
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="YEAR LEVEL"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:layout_marginBottom="24dp">
                
                <ImageView
                    android:id="@+id/ivYearIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/ic_calendar"
                    android:contentDescription="Year"/>

                <Spinner
                    android:id="@+id/spYear"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toEndOf="@id/ivYearIcon"
                    android:layout_toStartOf="@+id/ivYearArrow"
                    android:background="@android:color/transparent"
                    android:paddingHorizontal="12dp" />

                <ImageView
                    android:id="@+id/ivYearArrow"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_arrow_down"
                    android:tint="#A1A1AA"
                    android:contentDescription="Dropdown" />
            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="GENDER"
                android:textColor="#A1A1AA"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <RadioGroup
                android:id="@+id/rgGender"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">

                <RadioButton
                    android:id="@+id/rbMale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Male"
                    android:textColor="#A1A1AA"
                    android:textSize="14sp"
                    android:buttonTint="#FFFFFF"
                    android:layout_marginBottom="8dp"/>

                <RadioButton
                    android:id="@+id/rbFemale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Female"
                    android:textColor="#A1A1AA"
                    android:textSize="14sp"
                    android:buttonTint="#FFFFFF"
                    android:layout_marginBottom="8dp"/>
                    
                <RadioButton
                    android:id="@+id/rbOther"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Other"
                    android:textColor="#A1A1AA"
                    android:buttonTint="#FFFFFF"
                    android:textSize="14sp" />
            </RadioGroup>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnSubmit"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_button"
                android:text="Complete Registration"
                android:textColor="#000000"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false" />

        </LinearLayout>

        <!-- Removed disclaimer text as requested -->

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>
